# ============================================================
# TradingCup 環境変数テンプレート
# ============================================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local
#
# ⚠️ .env.local は .gitignore に含まれており、コミットされません
# ⚠️ 実際のキーや秘密情報をこのファイルに書かないでください
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- JWT ---
# ウォレット認証セッション用の署名秘密鍵（SERVICE_ROLE_KEYとは別にする）
# 生成例: openssl rand -base64 64
JWT_SIGNING_SECRET=your-jwt-signing-secret-here

# --- 暗号化 ---
# ユーザーAPIキーの暗号化用（AES-256-GCM）
# 生成例: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-here

# --- Admin ---
# 管理者メールアドレス（カンマ区切り）
ADMIN_EMAILS=admin@example.com

# --- Cron ---
# Vercel Cron認証用シークレット
# 生成例: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# --- WalletConnect ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- LBank（開発用） ---
# LBANK_MOCK_MODE=true にするとモックデータで動作
LBANK_MOCK_MODE=true
# LBANK_MOCK_SCENARIO=normal
